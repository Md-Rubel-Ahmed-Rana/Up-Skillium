{
  "name": "backend",
  "version": "1.0.0",
  "main": "./dist/server.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "start": "node -r tsconfig-paths/register dist/server.js",
    "test": "jest",
    "docker:build": "docker-compose build",
    "docker:start": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "lint-staged": "lint-staged",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@bugsnag/js": "^8.9.0",
    "@bugsnag/plugin-express": "^8.9.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "googleapis": "^144.0.0",
    "helmet": "^7.1.0",
    "http-status": "^2.0.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.0",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "stripe": "^17.3.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^13.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/http-status": "^1.1.2",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "resolutions": {
    "@types/express": "^4.17.21"
  }
}
